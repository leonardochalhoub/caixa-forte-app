# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Groq (M2+)
GROQ_API_KEY=your-groq-key
GROQ_PARSER_MODEL=llama-3.3-70b-versatile
GROQ_CHAT_MODEL=llama-3.3-70b-versatile
GROQ_WHISPER_MODEL=whisper-large-v3

# Telegram (M2+)
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_WEBHOOK_SECRET=change-me-32-random-chars

# Cron (M4+)
CRON_SECRET=change-me-32-random-chars

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000
APP_TIMEZONE=America/Sao_Paulo

# Demo — credenciais da conta de demonstração pública (Larissa)
# Usadas pelo /api/demo/enter pra minar cookies de sessão na visita
DEMO_EMAIL=larissa.demo@caixa-forte.app
DEMO_PASSWORD=change-me-strong-random-password

# Supabase Management API (PAT) — pra aplicar migrations via apply-pending.mjs
SUPABASE_ACCESS_TOKEN=sbp_xxx
SUPABASE_PROJECT_REF=your-project-ref
